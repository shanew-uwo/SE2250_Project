  CurrentIDCounter: 8
  json: '{"Options":[{"Connections":[],"EditorInfo":{"isRoot":false,"xPos":61.1130524,"yPos":334.791321},"ID":1,"ParamActions":[],"TMPFontGUID":null,"Text":"No,
    I hate working!","parentUIDs":[0],"SpeechUID":-1},{"Connections":[{"__type":"EditableSpeechConnection:#DialogueEditor","Conditions":[],"NodeUID":3}],"EditorInfo":{"isRoot":false,"xPos":308.2087,"yPos":333.121765},"ID":2,"ParamActions":[],"TMPFontGUID":null,"Text":"Yes,
    I''ll do free coffee runs if I have to!","parentUIDs":[0],"SpeechUID":-1}],"Parameters":[],"SpeechNodes":[{"Connections":[{"__type":"EditableOptionConnection:#DialogueEditor","Conditions":[],"NodeUID":1},{"__type":"EditableOptionConnection:#DialogueEditor","Conditions":[],"NodeUID":2}],"EditorInfo":{"isRoot":true,"xPos":79.4174042,"yPos":182.278275},"ID":0,"ParamActions":[],"TMPFontGUID":null,"Text":"Hey
    are you also looking for a job?","parentUIDs":[],"AdvanceDialogueAutomatically":false,"AudioGUID":null,"AutoAdvanceShouldDisplayOption":false,"IconGUID":null,"Name":null,"OptionUIDs":null,"SpeechUID":0,"TimeUntilAdvance":0,"Volume":0},{"Connections":[{"__type":"EditableSpeechConnection:#DialogueEditor","Conditions":[],"NodeUID":4}],"EditorInfo":{"isRoot":false,"xPos":173.808716,"yPos":421.6348},"ID":3,"ParamActions":[],"TMPFontGUID":null,"Text":"I
    think that company over there is hiring! Some sort of entry level unpaid internship.","parentUIDs":[2],"AdvanceDialogueAutomatically":false,"AudioGUID":null,"AutoAdvanceShouldDisplayOption":false,"IconGUID":null,"Name":"Desperate
    Student","OptionUIDs":null,"SpeechUID":0,"TimeUntilAdvance":0,"Volume":0},{"Connections":[{"__type":"EditableSpeechConnection:#DialogueEditor","Conditions":[],"NodeUID":5}],"EditorInfo":{"isRoot":false,"xPos":97.00871,"yPos":533.4957},"ID":4,"ParamActions":[],"TMPFontGUID":null,"Text":"However,
    there are a lot of desperate students trying to get it too! Watch out for them!","parentUIDs":[3],"AdvanceDialogueAutomatically":false,"AudioGUID":null,"AutoAdvanceShouldDisplayOption":false,"IconGUID":null,"Name":"Desperate
    Student","OptionUIDs":null,"SpeechUID":0,"TimeUntilAdvance":0,"Volume":0},{"Connections":[{"__type":"EditableSpeechConnection:#DialogueEditor","Conditions":[],"NodeUID":7}],"EditorInfo":{"isRoot":false,"xPos":332.417419,"yPos":523.478333},"ID":5,"ParamActions":[],"TMPFontGUID":null,"Text":"If
    you do see any desperate students, try yelling \"statics quiz\" (Press Q) and
    that should scare them off!","parentUIDs":[4],"AdvanceDialogueAutomatically":false,"AudioGUID":null,"AutoAdvanceShouldDisplayOption":false,"IconGUID":null,"Name":"Desperate
    Student","OptionUIDs":null,"SpeechUID":0,"TimeUntilAdvance":0,"Volume":0},{"Connections":[],"EditorInfo":{"isRoot":false,"xPos":283.165253,"yPos":622.817444},"ID":7,"ParamActions":[],"TMPFontGUID":null,"Text":"Hopefully
    you''ll make it to the interview. Good luck, and remember: if you don''t land
    this job your parents won''t love you!","parentUIDs":[5],"AdvanceDialogueAutomatically":false,"AudioGUID":null,"AutoAdvanceShouldDisplayOption":false,"IconGUID":null,"Name":"Desperate
    Student","OptionUIDs":null,"SpeechUID":0,"TimeUntilAdvance":0,"Volume":0}]}'
